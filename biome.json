{
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "correctness": {
        "noUnusedVariables": {
          "level": "error"
        },
        "noUnusedImports": {
          "level": "error"
        }
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/*.js",
      "!**/*.d.mts",
      "!**/node_modules",
      "!**/coverage",
      "!**/example",
      "!**/dist",
      "!**/pnpm-lock.yaml"
    ]
  }
}
