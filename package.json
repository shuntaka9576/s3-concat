{
  "name": "s3-concat",
  "version": "0.0.0-semantically-released",
  "description": "Concatenate multiple files in AWS S3 using multipart upload.",
  "type": "module",
  "main": "dist/s3-concat.cjs",
  "types": "dist/s3-concat.d.mts",
  "module": "dist/s3-concat.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/s3-concat.d.mts",
        "default": "./dist/s3-concat.mjs"
      },
      "require": {
        "types": "./dist/s3-concat.d.cts",
        "default": "./dist/s3-concat.cjs"
      }
    }
  },
  "bin": {
    "s3-concat": "dist/cli.mjs"
  },
  "scripts": {
    "build": "tsdown",
    "fix": "biome check . --write --unsafe",
    "check": "pnpm run check:lint && pnpm run check:format && pnpm run check:type && pnpm run check:spell",
    "check:lint": "biome lint .",
    "check:format": "biome format .",
    "check:type": "tsc",
    "check:spell": "cspell lint . --cache --gitignore",
    "test": "vitest run --config vitest.config.ts --coverage.enabled true --reporter=verbose",
    "test:unit": "vitest run --config vitest.unit.config.ts --reporter=verbose",
    "test:sdk-matrix": "bash scripts/sdk-matrix.sh test",
    "e2e": "USE_REAL_S3=1 vitest run --config vitest.config.ts --reporter=verbose",
    "e2e:sdk-matrix": "bash scripts/sdk-matrix.sh e2e",
    "publish": "semantic-release"
  },
  "author": "shuntaka9576",
  "license": "MIT",
  "packageManager": "pnpm@11.15.1",
  "peerDependencies": {
    "@aws-sdk/client-s3": ">=3.300.0 <4.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "3.1090.0",
    "@biomejs/biome": "2.5.3",
    "@floci/testcontainers": "0.1.0",
    "@semantic-release/exec": "^7.1.0",
    "@vitest/coverage-v8": "4.1.10",
    "cspell": "10.0.1",
    "semantic-release": "25.0.6",
    "tsdown": "^0.22.9",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shuntaka9576/s3-concat.git"
  },
  "bugs": {
    "url": "https://github.com/shuntaka9576/s3-concat/issues"
  },
  "homepage": "https://github.com/shuntaka9576/s3-concat#readme",
  "keywords": [
    "aws",
    "s3",
    "concatenate",
    "multipart upload",
    "nodejs"
  ],
  "engines": {
    "node": ">=22.22.3 <27"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "pnpm run build"
        }
      ],
      "@semantic-release/github"
    ]
  }
}
