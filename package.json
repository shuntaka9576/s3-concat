{
  "name": "s3-concat",
  "version": "0.0.0-semantically-released",
  "description": "Concatenate multiple files in AWS S3 using multipart upload.",
  "type": "module",
  "main": "dist/s3-concat.umd.cjs",
  "types": "dist/lib/s3-concat.d.ts",
  "module": "dist/s3-concat.js",
  "exports": {
    ".": {
      "types": "./dist/lib/s3-concat.d.ts",
      "import": "./dist/s3-concat.js",
      "require": "./dist/s3-concat.umd.cjs"
    }
  },
  "scripts": {
    "build": "pnpm run clean && vite build",
    "fix": "biome check . --write --unsafe",
    "check": "pnpm run check:lint && pnpm run check:format && pnpm run check:type && pnpm run check:spell",
    "check:lint": "biome lint .",
    "check:format": "biome format .",
    "check:type": "tsc",
    "check:spell": "cspell lint . --cache --gitignore",
    "clean": "rimraf dist",
    "test": "vitest run --config vitest.config.ts --coverage.enabled true --reporter=verbose",
    "test:unit": "vitest run --config vitest.unit.config.ts --reporter=verbose",
    "test:sdk-matrix": "bash scripts/sdk-matrix.sh test",
    "e2e": "USE_REAL_S3=1 vitest run --config vitest.config.ts --reporter=verbose",
    "e2e:sdk-matrix": "bash scripts/sdk-matrix.sh e2e",
    "publish": "semantic-release"
  },
  "author": "shuntaka9576",
  "license": "MIT",
  "packageManager": "pnpm@10.34.3",
  "peerDependencies": {
    "@aws-sdk/client-s3": ">=3.300.0 <4.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "3.1070.0",
    "@biomejs/biome": "2.5.0",
    "@floci/testcontainers": "0.1.0",
    "@vitest/coverage-v8": "3.2.6",
    "cspell": "10.0.1",
    "rimraf": "6.1.3",
    "semantic-release": "25.0.5",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-plugin-dts": "5.0.2",
    "vitest": "3.2.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shuntaka9576/s3-concat.git"
  },
  "bugs": {
    "url": "https://github.com/shuntaka9576/s3-concat/issues"
  },
  "homepage": "https://github.com/shuntaka9576/s3-concat#readme",
  "keywords": [
    "aws",
    "s3",
    "concatenate",
    "multipart upload",
    "nodejs"
  ],
  "engines": {
    "node": ">=22.22.3"
  },
  "release": {
    "branches": [
      "main"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ]
  }
}
